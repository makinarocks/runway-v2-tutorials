# Energy Demand GUI — nginx + Vite 빌드
#
# Gitea Actions (build-gui-image.yml) 가 자동 빌드 & CR 푸시.

FROM node:20-alpine AS build
WORKDIR /app
COPY gui/package*.json ./
RUN npm install
COPY gui/ ./
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY gui/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
