# ================================================================
# wind-power-prediction 튜토리얼 환경설정 템플릿
# 이 파일을 `.env` 로 복사한 뒤 본인 값으로 채우세요.
#
#     cp .env.example .env
#
# .env 는 .gitignore 에 포함되어 있어 저장소에 커밋되지 않습니다.
# IDE 스크립트(download_model.py / test_inference.py)가 config.py
# 를 통해 자동으로 이 파일을 읽습니다.
# ================================================================

# ── [필수] 사용자마다 다른 값 ─────────────────────────────────────

# Runway 프로젝트 식별자. 이 한 값으로 아래가 모두 자동 파생됩니다:
#   - K8s namespace / S3 bucket / OpenBao namespace / Gitea 조직
#   - 컨테이너 이미지 경로, MLflow experiment 이름, 모델 이름
RUNWAY_PROJECT_ID=rwyt-energy-forecasting

# OpenBao 서비스 토큰. OpenBao 웹 콘솔 우측 상단에서 본인 namespace
# (= RUNWAY_PROJECT_ID) 로 로그인하면 자동 발급됩니다. 만료 시 재로그인.
OPENBAO_TOKEN=s.여기에_토큰_붙여넣기


# ── [선택] 추론 테스트용 (test_inference.py) ──────────────────────
# WALKTHROUGH 9단계 (모델 배포) 완료 후 엔드포인트 상세 페이지에서
# "추론 URL" 을 복사해 채우세요. 10단계 추론 테스트 전까지는 빈 값으로 둬도 됩니다.
#
# INFERENCE_ENDPOINT : 형식 https://inference.v2.mrxrunway.ai/api/<proj>/<endpoint>/<deployment>
#                       (UI 의 "추론 URL" 을 그대로 복사 — 프로젝트/엔드포인트/배포 경로 포함)
# DEPLOYMENT_ID      : KServe V2 models/<name>/infer 의 <name> 값. Runway MLServer 는 'default' 고정.

INFERENCE_ENDPOINT=
DEPLOYMENT_ID=default


# ── [드물게 필요] override 용 ──────────────────────────────────────
# 아래 값들은 기본값으로 충분하면 주석 처리한 채로 두세요.
# 특수한 프로젝트 규약을 쓰거나 자체 서명 인증서 환경일 때만 활성화.
#
# OPENBAO_VERIFY_TLS=false       # 자체 서명 OpenBao 환경
# INFERENCE_VERIFY_TLS=false     # 자체 서명 추론 게이트웨이
# NAMESPACE=some-other-namespace # K8s namespace 가 PROJECT_ID 와 다를 때
# S3_BUCKET=some-other-bucket    # S3 bucket 이 PROJECT_ID 와 다를 때
# IMAGE_TAG=v1.0.0               # :latest 대신 특정 태그 사용 시
# EXPERIMENT_SHORT_NAME=wind-power-prediction  # experiment 이름 변경 시
